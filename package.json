{
  "name": "website-revamp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "lint": "eslint",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "migrate": "cross-env NODE_OPTIONS=--no-deprecation payload migrate",
    "push:schema": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/push-schema.ts",
    "seed": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/seed.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@payloadcms/db-postgres": "^3.85.1",
    "@payloadcms/next": "^3.85.1",
    "@payloadcms/richtext-lexical": "^3.85.1",
    "@payloadcms/ui": "^3.85.1",
    "cross-env": "^10.1.0",
    "framer-motion": "^12.40.0",
    "graphql": "^16.8.1",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "next": "16.2.9",
    "payload": "^3.85.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.80.0",
    "resend": "^6.14.0",
    "sharp": "^0.35.2",
    "tsx": "^4.22.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
